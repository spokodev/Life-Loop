{
  "name": "@life-loop/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "biome check src",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:db": "node --import tsx --test --test-concurrency=1 src/integration/**/*.db-test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^2.33.1",
    "@hono/node-server": "^1.13.7",
    "@life-loop/config": "workspace:*",
    "@life-loop/shared-types": "workspace:*",
    "hono": "^4.6.14",
    "pg": "^8.13.1",
    "stripe": "^17.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10"
  }
}
