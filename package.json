{
  "name": "life-loop",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@life-loop/web --filter=@life-loop/api",
    "dev:web": "pnpm --filter @life-loop/web dev",
    "dev:api": "pnpm --filter @life-loop/api dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:db:api": "pnpm --filter @life-loop/api test:db",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "docs:check": "node ./scripts/verify-docs.mjs",
    "prod:check": "node ./scripts/verify-production-config.mjs",
    "smoke:health": "node ./scripts/smoke-health.mjs",
    "compose:validate": "docker compose -f docker-compose.dev.yml config >/dev/null && docker compose -f infra/docker/docker-compose.prod.template.yml config >/dev/null",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "pnpm --filter @life-loop/api db:migrate",
    "check": "biome check . && pnpm docs:check && turbo run typecheck test && pnpm compose:validate && pnpm prod:check",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@biomejs/biome": "^2.0.0",
    "tsx": "^4.19.2",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  }
}
