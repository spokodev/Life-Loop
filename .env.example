# Root workspace defaults
NODE_ENV=development

# apps/web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# apps/api
API_HOST=0.0.0.0
API_PORT=4000
DATABASE_URL=postgres://lifeloop:lifeloop@localhost:5434/lifeloop
CORS_ORIGIN=http://localhost:3000
CLERK_ISSUER_URL=
# Required when CLERK_ISSUER_URL enables API user auth.
# Reuse the same Clerk secret as the web app in single-project deployments.
CLERK_SECRET_KEY=
LOG_LEVEL=info

# apps/desktop-agent
LIFE_LOOP_AGENT_ID=dev-agent
LIFE_LOOP_LIBRARY_ID=dev-library
LIFE_LOOP_CONTROL_PLANE_URL=http://localhost:4000
LIFE_LOOP_HEARTBEAT_INTERVAL=30s
LIFE_LOOP_HEALTH_PORT=8081
LIFE_LOOP_STORAGE_BINDINGS_PATH=
